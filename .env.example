# Local dev: copy to .env and adjust. In production (Render) set these in the dashboard.

# Postgres connection. Local default is used if unset.
DATABASE_URL=postgres://bekagogava@localhost:5432/venue_os

# Login password (what users type on /login). Change in production.
APP_PASSWORD=avenue

# Session secret (the auth cookie value). Use a long random string in production.
AUTH_SECRET=avos-dev-secret-change-me
